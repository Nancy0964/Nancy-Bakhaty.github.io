              </div>
              <section class="project-outcome"><h3>Outcome</h3><p>Add results, feedback, or next steps.</p></section>
            </div>
          </div>
        </article>

        <article class="project-panel" data-project-panel data-project-title="Project Orbit" aria-labelledby="project-orbit-title">
          <div class="project-panel__shell">
            <header class="project-panel__top">
              <p class="project-number">04</p>
