                <figure><img src="project_showcase_component/assets/echo-detail-1.svg" alt="Placeholder detail visual showing Project Echo wireframes" /><figcaption>Wireframes</figcaption></figure>
                <figure><img src="project_showcase_component/assets/echo-detail-2.svg" alt="Placeholder detail visual showing Project Echo final design" /><figcaption>Final design</figcaption></figure>
              </div>
              <div class="video-block">
                <video controls preload="metadata" poster="project_showcase_component/assets/echo-poster.svg"><source src="project_showcase_component/assets/placeholder-demo.mp4" type="video/mp4" />Your browser does not support the video element.</video>
